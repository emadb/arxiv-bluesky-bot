# Copy to .env and fill in. Source it before running:
#   set -a && source .env && set +a

# --- required ---
BSKY_HANDLE=your-bot.bsky.social
BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # a Bluesky App Password, never your real password

# --- optional (defaults shown) ---
# BSKY_SERVICE=https://bsky.social
# ARXIV_CATEGORIES=cs.AI                # e.g. cs, cs.AI, or cs.AI+cs.LG (max 2000 results)
# ARXIV_ANNOUNCE_TYPES=new              # comma-separated: new,cross,replace,replace-cross
# MAX_POSTS=50
# POST_DELAY_MS=1500
# ARXIV_TIMEZONE=America/New_York
# POST_WINDOWS=6                        # 1 = post the whole batch in one run (use for backfills)
# TARGET_DATE=                          # YYYY-MM-DD; empty = today in ARXIV_TIMEZONE
# DRY_RUN=false                         # true = log posts but don't publish
